; installs libusb-win32 drivers for Apple devices
[Strings]
VendorName = "Apple, Inc."
SourceName = "Apple Device Install Disk"
DeviceGUID = "{B23E0DDC-E3F4-46A0-9D55-B60171DB66E4}"
; values are taken from https://theapplewiki.com/wiki/USB_Product_IDs and https://devicehunt.com/view/type/usb/vendor/05AC/
DeviceName_1290 = "Apple iPhone USB Device"
DeviceName_1291 = "Apple iPod touch (1st gen) USB Device"
DeviceName_1292 = "Apple iPhone 3G USB Device"
DeviceName_1293 = "Apple iPod touch (2nd gen) USB Device"
DeviceName_1294 = "Apple iPhone 3GS USB Device"
DeviceName_1295 = "Apple USB Device"
DeviceName_1296 = "Apple iPod touch (3rd gen) USB Device"
DeviceName_1297 = "Apple iPhone 4 USB Device"
DeviceName_1298 = "Apple USB Device"
DeviceName_1299 = "Apple iPod touch (3rd gen) USB Device"
DeviceName_129A = "Apple iPad USB Device"
DeviceName_129B = "Apple USB Device"
DeviceName_129C = "Apple iPhone 4 (CDMA) USB Device"
DeviceName_129D = "Apple iPhone USB Device"
DeviceName_129E = "Apple iPod touch (4th gen) USB Device"
DeviceName_129F = "Apple iPad (2nd gen) USB Device"
DeviceName_12A0 = "Apple iPhone 4S USB Device"
DeviceName_12A1 = "Apple iPhone USB Device"
DeviceName_12A2 = "Apple iPad (2nd gen) (3G; 64GB) USB Device"
DeviceName_12A3 = "Apple iPad (2nd gen (CDMA) USB Device"
DeviceName_12A4 = "Apple iPad (3rd gen) (WiFi) USB Device"
DeviceName_12A5 = "Apple iPad (3rd gen) (CDMA) USB Device"
DeviceName_12A6 = "Apple iPad (3rd gen) (3G; 64GB) USB Device"
DeviceName_12A7 = "Apple TV USB Device"
DeviceName_12A8 = "Apple iPhone 5 and later USB Device"
DeviceName_12A9 = "Apple iPad (4th or 2nd gen) USB Device"
DeviceName_12AA = "Apple iPod touch (5th/6th/7th gen) USB Device"
DeviceName_12AB = "Apple iPad (newer models) USB Device"
DeviceName_12AC = "Apple TV Restore Mode or iPhone USB Device"
DeviceName_12AD = "Apple Lightning Digital AV Adapter USB Device"
DeviceName_12AE = "Apple Lightning VGA Adapter USB Device"
DeviceName_12AF = "Apple Watch USB Device"

[Version]
Signature   = "$Windows NT$"
Class       = "Apple Devices"
ClassGuid   = {88BAE032-5A81-49f0-BC3D-A4FF138216D6}
Provider    = "rusbmux"
CatalogFile = rusbmux_libusb0.cat
DriverVer   = 01/09/2026, 1.4.0.2

[Manufacturer]
%VendorName% = Devices, NT, NTAMD64, NTARM64

;--------------------------------------------------------------------------
; libusb-win32 files
;--------------------------------------------------------------------------

[SourceDisksNames]
1 = %SourceName%

[SourceDisksFiles.x86]
libusb0.sys     = 1,x86
libusb0_x86.dll = 1,x86

[SourceDisksFiles.amd64]
libusb0.sys     = 1,amd64
libusb0.dll     = 1,amd64
libusb0_x86.dll = 1,x86

[SourceDisksFiles.arm64]
libusb0.sys     = 1,arm64
libusb0.dll     = 1,arm64

[DestinationDirs]
libusb_files_sys       = 10,system32\drivers
libusb_files_dll       = 10,system32
libusb_files_dll_wow64 = 10,syswow64
libusb_files_dll_x86   = 10,system32

[libusb_files_sys]
libusb0.sys

[libusb_files_dll]
libusb0.dll

[libusb_files_dll_x86]
libusb0.dll, libusb0_x86.dll

[libusb_files_dll_wow64]
libusb0.dll, libusb0_x86.dll

; (Optional) the usb configuration value to select when this device
; is started.  If this key does not exist the first config is selected.
;HKR,,InitialConfigValue,0x00010001,<your config value>

;--------------------------------------------------------------------------
; libusb-win32 service
;--------------------------------------------------------------------------

[libusb_add_service]
DisplayName   = "libusb-win32 - Kernel Driver 01/09/2026 1.4.0.2"
ServiceType   = 1
StartType     = 3
ErrorControl  = 0
ServiceBinary = %12%\libusb0.sys

;--------------------------------------------------------------------------
; libusb-win32 devices
;--------------------------------------------------------------------------

; Hardware IDs in a 'Devices' section can be installed by libusb-win32
; using usb_install_driver_np(), usb_install_driver_np_rundll(), or the
; inf-wizard utility.
;

;--------------------------------------------------------------------------
; libusb-win32 device driver
; 
; handles per pid device name and friendly name 
;--------------------------------------------------------------------------

[LIBUSB_WIN32_DEV_1290.NT]
CopyFiles = libusb_files_sys, libusb_files_dll_x86

[LIBUSB_WIN32_DEV_1290.NT.Services]
AddService = libusb0, 0x00000002, libusb_add_service

[LIBUSB_WIN32_DEV_1290.NT.HW]
DelReg = libusb_del_reg_hw
AddReg = libusb_add_reg_hw, libusb_add_reg_friendlyname_1290

; -----

