# Maintainer: Abdullah Al-Banna <abdu.albanna@proton.me>

pkgname=rusbmux
pkgver=VERSION_PLACEHOLDER
pkgrel=1
pkgdesc="A usbmuxd replacement in pure Rust"
arch=('ARCH_PLACEHOLDER')
url="https://github.com/abdullah-albanna/rusbmux"
license=('MIT' 'Apache-2.0')
depends=('glibc' 'gcc-libs')
provides=('rusbmux' 'usbmuxd')
conflicts=('usbmuxd')
replaces=('usbmuxd')
source=("$pkgname-$pkgver.tar.gz::https://github.com/abdullah-albanna/rusbmux/archive/v$pkgver.tar.gz")
md5sums=('SKIP')

package() {
    cd "$srcdir/$pkgname-$pkgver"

    install -Dm 755 target/release/rusbmux "${pkgdir}/usr/bin/rusbmux"
    install -Dm 644 systemd/rusbmux.service "${pkgdir}/usr/lib/systemd/system/rusbmux.service"
    install -Dm 644 README.md "${pkgdir}/usr/share/doc/rusbmux/README.md"
    install -Dm 644 LICENSE-MIT "${pkgdir}/usr/share/licenses/rusbmux/LICENSE-MIT"
    install -Dm 644 LICENSE-APACHE "${pkgdir}/usr/share/licenses/rusbmux/LICENSE-APACHE"
    install -Dm 644 THIRD_PARTY_LICENSES.txt "${pkgdir}/usr/share/licenses/rusbmux/THIRD_PARTY_LICENSES.txt"
}

# vim:set ts=2 sw=2 et:
